PORT=4000
TRUST_PROXY=false

DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
DB_MIGRATIONS_RUN=true

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=holat_backend
DB_SYNC=false
DB_LOGGING=false

JWT_SECRET=replace_with_at_least_32_characters_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_at_least_32_characters_secret
JWT_REFRESH_EXPIRES_IN=30d
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOGIN_LOCK_MINUTES=15

CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174
THROTTLE_TTL=60000
THROTTLE_LIMIT=120
SWAGGER_ENABLED=true

UPLOAD_DRIVER=local
UPLOAD_DIR=uploads
UPLOAD_MAX_FILE_MB=5
UPLOAD_PUBLIC_BASE_URL=
UPLOAD_CLEANUP_DAYS=30

S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

METRICS_ENABLED=true
METRICS_API_KEY=
ALERT_ERROR_RATE_THRESHOLD=0.2

SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
